{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/[category]/layout,_N_T_/docs/[category]/page,_N_T_/docs/reference"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/$d$category/__PAGE__",
    "/docs/$d$category",
    "/docs",
    "/_index",
    "/_head"
  ]
}